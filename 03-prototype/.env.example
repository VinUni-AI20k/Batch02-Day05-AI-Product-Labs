# Copy thành .env và điền key (KHÔNG commit .env)

# Chọn provider: auto | openai | deepseek | gemini
# auto = ưu tiên: OpenAI → DeepSeek → Gemini (key nào có trước)
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tuỳ chọn: Google Custom Search (nguồn web khi dùng OpenAI / DeepSeek)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

PORT=3000
