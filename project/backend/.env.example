# ============================================================
# .env.example - Mẫu biến môi trường
# Template for environment variables configuration
#
# HƯỚNG DẪN / INSTRUCTIONS:
#   1. Sao chép tệp này thành .env / Copy this file to .env:
#      cp .env.example .env
#   2. Điền giá trị thực vào / Fill in real values
#   3. KHÔNG commit .env vào git! / NEVER commit .env to git!
# ============================================================

# ── LLM API Keys (Bắt buộc ít nhất 1 / At least 1 required) ─────────────────

# OpenAI API Key - Lấy từ / Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API Key - Lấy từ / Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Model Configuration / Cấu hình mô hình ───────────────────────────────────

# Tên mô hình mặc định / Default LLM model name
# OpenAI options:  gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Gemini options:  gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
MODEL_NAME=gpt-4o

# ── Cost Control / Kiểm soát chi phí ─────────────────────────────────────────

# Giới hạn chi phí tối đa mỗi ngày (USD) / Maximum daily cost limit per user (USD)
# Khi vượt giới hạn, user sẽ nhận được lỗi 429 / When exceeded, user gets 429 error
MAX_DAILY_COST_USD=1.00

# ── Rate Limiting / Giới hạn tốc độ ─────────────────────────────────────────

# Số tin nhắn tối đa mỗi phút cho /api/chat / Max chat messages per minute per user
RATE_LIMIT_PER_MINUTE=5

# ── Server Configuration / Cấu hình máy chủ ─────────────────────────────────

# Địa chỉ và cổng server / Server host and port
HOST=0.0.0.0
PORT=8000

# Bật/tắt chế độ debug / Enable/disable debug mode
# DEBUG=true sẽ bật auto-reload và raw LLM responses trong kết quả analyze
# DEBUG=true enables hot-reload and includes raw LLM response in analyze output
DEBUG=false

# ── CORS Configuration / Cấu hình CORS ───────────────────────────────────────

# Danh sách origins được phép (phân cách bởi dấu phẩy)
# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Admin Security / Bảo mật Admin ───────────────────────────────────────────

# API key cho các endpoint admin / API key for admin endpoints
# Đổi thành chuỗi ngẫu nhiên dài trong production!
# Change to a long random string in production!
# Tạo ngẫu nhiên / Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=dev-admin-key-change-in-production

# ── Database / Cơ sở dữ liệu ─────────────────────────────────────────────────

# Thư mục lưu file SQLite / Directory for SQLite database files
# Mặc định: ./data/ / Default: ./data/
# DB_DIR=./data
